# --- Database (MongoDB via Prisma) ---
DATABASE_URL="mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority"

# --- Auth ---
JWT_SECRET_KEY="change-me"

# --- Server ---
# Local default; on Render/Railway/Fly the platform injects PORT.
PORT=9999
NODE_ENV=development

# --- CORS ---
# Origin(s) allowed to call the API and connect over Socket.IO.
# Single origin, or a comma-separated list for multiple frontends.
CORS_ORIGIN=http://localhost:3000

# --- /v2 internal gate ---
# Required for any /v2 endpoint to respond (otherwise 404).
V2_INTERNAL_ENABLED=true
# Optional extra gate: if set, clients must send header x-internal-v2-token.
V2_INTERNAL_TOKEN=

# --- Cloudinary (media uploads) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
